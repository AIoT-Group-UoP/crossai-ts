    "   \"source\": \"## ColumnTransformer\",\n",
    "   \"id\": \"7f301941ab62168e\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-23T12:58:51.717956Z\",\n",
    "     \"start_time\": \"2026-01-23T12:58:51.713590Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from caits.filtering import filter_median_gen\\n\",\n",
    "    \"from caits.transformers import ColumnTransformer\\n\",\n",
    "    \"from sklearn.preprocessing import StandardScaler\\n\",\n",
    "    \"from sklearn.pipeline import Pipeline\\n\",\n",
    "    \"from caits.properties import magnitude_signal\\n\",\n",
    "    \"\\n\",\n",
    "    \"pipe_filter = Pipeline(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        (\\\"median\\\", FunctionTransformer(filter_median_gen, window_size=20, to_y=True)),\\n\",\n",
    "    \"        (\\\"butterworth\\\", FunctionTransformer(filter_butterworth, fs=10, filter_type='highpass', cutoff_freq=2, to_y=True))\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"pipe_scaler = SklearnPipeStep(StandardScaler)\\n\",\n",
    "    \"\\n\",\n",
    "    \"mag_tr = FeatureExtractorSignal(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        {\\n\",\n",
    "    \"            \\\"func\\\": magnitude_signal,\\n\",\n",
    "    \"            \\\"params\\\": {\\n\",\n",
    "    \"                \\\"axis\\\": 1\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"    ], axis=1\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"column_tr1 = ColumnTransformer(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"filter_acc_x_gyr_x\\\",\\n\",\n",
    "    \"            pipe_filter,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"NO2(GT)\\\", \\\"CO(GT)\\\"], [\\\"new_NO2\\\", \\\"new_CO\\\"]),\\n\",\n",
    "    \"                # \\\"y\\\": ([\\\"RH\\\", \\\"AH\\\"], [\\\"new_RH\\\", \\\"new_AH\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        ),\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"filter_acc_y_gyr_y\\\",\\n\",\n",
    "    \"            pipe_filter,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"T\\\", \\\"NMHC(GT)\\\"], [\\\"new_T\\\", \\\"new_NMHC\\\"]),\\n\",\n",
    "    \"                \\\"y\\\": ([\\\"RH\\\", \\\"AH\\\"], [\\\"new_RH\\\", \\\"new_AH\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    unify=False\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"column_tr2 = ColumnTransformer(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"scale_acc_x_acc_y_acc_z\\\",\\n\",\n",
    "    \"            pipe_scaler,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"NO2(GT)\\\", \\\"CO(GT)\\\"], [\\\"scaled_NO2\\\", \\\"scaled_CO\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    unify=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"column_tr3 = ColumnTransformer(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"mag_calc_1\\\",\\n\",\n",
    "    \"            mag_tr,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"NO2(GT)\\\", \\\"CO(GT)\\\"], [\\\"mag_NO2_CO\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        ),\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"mag_calc_2\\\",\\n\",\n",
    "    \"            mag_tr,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"T\\\", \\\"NMHC(GT)\\\"], [\\\"mag_T_NHMC\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        ),\\n\",\n",
    "    \"        (\\n\",\n",
    "    \"            \\\"mag_calc_3\\\",\\n\",\n",
    "    \"            mag_tr,\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"X\\\": ([\\\"scaled_NO2\\\", \\\"scaled_CO\\\"], [\\\"mag_scaled_NO2_CO\\\"])\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        ),\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    unify=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"final_pipe = Pipeline(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        (\\\"filter\\\", column_tr1),\\n\",\n",
    "    \"        (\\\"scale\\\", column_tr2),\\n\",\n",
    "    \"        (\\\"mag\\\", column_tr3),\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \")\\n\"\n",
    "   ],\n",
