    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-23T12:58:49.892922Z\",\n",
    "     \"start_time\": \"2026-01-23T12:58:49.889551Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"data_X_vals = data_X.values\\n\",\n",
    "    \"data_X_axis_names = {\\\"axis_1\\\": data_X.columns}\\n\",\n",
    "    \"data_y_vals = data_y.values\\n\",\n",
    "    \"data_y_axis_names = {\\\"axis_1\\\": data_y.columns}\\n\",\n",
    "    \"data_X = CoreArray(values=data_X_vals, axis_names=data_X_axis_names)\\n\",\n",
    "    \"data_y = CoreArray(values=data_y_vals, axis_names=data_y_axis_names)\\n\",\n",
    "    \"datasetArrayObj = DatasetArray(data_X, data_y)\"\n",
    "   ],\n",
