    "    \"scaler = SklearnPipeStep(StandardScaler, to_X=True, to_y=True)\\n\",\n",
    "    \"dataInverseFlatten = ArrayToDataset(\\n\",\n",
    "    \"    shape_X=tmp.X.shape,\\n\",\n",
    "    \"    shape_y=tmp.y.shape,\\n\",\n",
    "    \"    to_X=True,\\n\",\n",
