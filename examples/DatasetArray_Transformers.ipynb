    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# Transformers and Pipelines test on DatasetArray object\\n\",\n",
    "    \"\\n\",\n",
    "    \"In this notebook we check the `caits.transformers` and Sklearn Pipelines consisting of `caits.transformers`.\\n\"\n",
    "   ],\n",
    "   \"id\": \"b5213e6cd83ab3b2\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Importing libraries\",\n",
    "   \"id\": \"7b368feaaec9e618\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-23T12:58:49.841115Z\",\n",
    "     \"start_time\": \"2026-01-23T12:58:49.276989Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from caits.filtering import filter_butterworth\\n\",\n",
    "    \"from caits.fe import mean_value, std_value, stft, istft, melspectrogram\\n\",\n",
    "    \"from caits.dataset import CoreArray, DatasetArray\\n\",\n",
    "    \"from caits.transformers import (\\n\",\n",
    "    \"    FunctionTransformer,\\n\",\n",
    "    \"    FunctionTransformer2D,\\n\",\n",
    "    \"    FeatureExtractorSignal,\\n\",\n",
    "    \"    FeatureExtractorSpectrum,\\n\",\n",
    "    \"    FeatureExtractorScalar,\\n\",\n",
    "    \"    SlidingWindow\\n\",\n",
    "    \")\"\n",
    "   ],\n",
    "   \"id\": \"22670bfae1ffe7b6\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"## Dataset loading\\n\",\n",
    "    \"\\n\",\n",
    "    \"For this notebook, we will use the data/AirQuality.csv dataset.\"\n",
    "   ],\n",
    "   \"id\": \"ee19791e45fe2574\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-01-23T12:58:49.860306Z\",\n",
    "     \"start_time\": \"2026-01-23T12:58:49.844477Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"data = pd.read_csv(\\\"data/AirQuality.csv\\\", sep=\\\";\\\", decimal=\\\",\\\")\\n\",\n",
    "    \"data_X = data.iloc[:, 2:-4]\\n\",\n",
    "    \"data_X = data_X.fillna(data_X.mean())\\n\",\n",
    "    \"data_y = data.iloc[:, -4:-2]\\n\",\n",
    "    \"data_y = data_y.fillna(data_y.mean())\"\n",
    "   ],\n",
    "   \"id\": \"20f1fc3d73659d03\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
